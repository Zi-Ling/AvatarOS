# AvatarOS Docker Configuration
# 1. Copy this file: cp .env.example .env
# 2. Fill in your LLM API Key
# 3. Start: docker compose up -d

# ============================================================
# LLM Configuration (required)
# Supports DeepSeek / OpenAI / any OpenAI-compatible API
# ============================================================
LLM_API_KEY=your_api_key_here
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com

# OpenAI example:
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o
# LLM_BASE_URL=https://api.openai.com/v1

# Local Ollama example:
# LLM_API_KEY=ollama
# LLM_MODEL=qwen2.5:7b
# LLM_BASE_URL=http://localhost:11434/v1

# ============================================================
# Web Search Configuration (optional)
# SearXNG is built-in and works out of the box, no config needed.
# For higher quality search, configure a commercial API
# (priority: Brave > Google > Tavily)
# ============================================================
# BRAVE_API_KEY=
# GOOGLE_CSE_KEY=
# GOOGLE_CSE_ID=
# TAVILY_API_KEY=

# ============================================================
# Server Configuration (optional, has defaults)
# ============================================================
# LOG_LEVEL=INFO
