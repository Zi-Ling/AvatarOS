# AvatarOS 后端环境变量配置
# 复制此文件为 .env 并填入你的配置
# cp .env.example .env

# ============================================================
# LLM 配置（必填）
# 支持 DeepSeek / OpenAI / 任何兼容 OpenAI 接口的服务
# ============================================================
LLM_API_KEY=your_api_key_here
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com

# OpenAI 示例：
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o
# LLM_BASE_URL=https://api.openai.com/v1

# 本地 Ollama 示例：
# LLM_API_KEY=ollama
# LLM_MODEL=qwen2.5:7b
# LLM_BASE_URL=http://localhost:11434/v1

# ============================================================
# 服务器配置（可选，有默认值）
# ============================================================
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8000
# LOG_LEVEL=INFO

# ============================================================
# API 认证（可选）
# 设置后所有 API 请求需携带 Authorization: Bearer <token>
# 不设置则无需认证（适合本地开发）
# ============================================================
# API_TOKEN=your_secret_token_here

# ============================================================
# Vision LLM（可选，桌面 GUI 自动化需要）
# computer.use 技能需要支持视觉的 LLM 来分析截图
# 不配置则桌面自动化功能不可用
# ============================================================
# VISION_LLM_BASE_URL=https://api.openai.com
# VISION_LLM_MODEL=gpt-4o
# VISION_LLM_API_KEY=your_vision_api_key_here
# VISION_LLM_PROVIDER=openai

# ============================================================
# 持久化任务状态机（可选）
# 启用后长时任务支持 Checkpoint/恢复、心跳租约、崩溃恢复
# 默认关闭，不影响现有任务流程
# ============================================================
# DURABLE_STATE_ENABLED=false
# DURABLE_HEARTBEAT_INTERVAL_S=30
# DURABLE_LEASE_TIMEOUT_S=90
# DURABLE_CHECKPOINT_INTERVAL=5
# DURABLE_DUAL_WRITE=false
# DURABLE_RECOVERY_SCAN=true
# DURABLE_EFFECT_LEDGER=true

# ============================================================
# 网络搜索（可选）
# 不配置则使用 DuckDuckGo 免费搜索
# 配置商业 API 可获得更高质量结果
# 优先级：Brave > Google CSE > Tavily
# ============================================================
# BRAVE_API_KEY=
# GOOGLE_CSE_KEY=
# GOOGLE_CSE_ID=
# TAVILY_API_KEY=
